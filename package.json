{
  "name": "hermes-ide",
  "version": "1.0.0",
  "description": "Hermes IDE — A native macOS menu bar IDE powered by Hermes Agent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "keywords": [
    "hermes",
    "ide",
    "editor",
    "ai"
  ],
  "author": "pastorello",
  "license": "MIT",
  "build": {
    "appId": "com.hermes.ide",
    "productName": "Hermes IDE",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ]
    },
    "dmg": {
      "title": "Hermes IDE",
      "icon": "build/icon.icns",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "app.js",
      "slash-commands.js",
      "hermes-bridge.py",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "emmet": "^2.4.11",
    "lucide": "^1.17.0",
    "material-icons": "^1.13.14",
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-webgl": "^0.16.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1"
  }
}
